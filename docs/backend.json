
{
  "entities": {
    "Admin": {
      "title": "Admin",
      "type": "object",
      "description": "Profil administrateur.",
      "properties": {
        "prenom": { "type": "string" },
        "nom": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" }
      },
      "required": ["prenom", "email"]
    },
    "Adherent": {
      "title": "Adherent",
      "type": "object",
      "description": "Membre de l'association.",
      "properties": {
        "nom": { "type": "string" },
        "prenom": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telephone": { "type": "string" },
        "adresse": { "type": "string" },
        "dateNaissance": { "type": "string", "format": "date-time" },
        "genre": { "type": "string", "enum": ["H", "F", "Autre"] },
        "dateInscription": { "type": "string", "format": "date-time" },
        "estMembreBureau": { "type": "boolean" },
        "estBenevole": { "type": "boolean" },
        "estMembreFaaf": { "type": "boolean" },
        "accordeDroitImage": { "type": "boolean" },
        "cotisationAJour": { "type": "boolean" }
      },
      "required": ["nom", "prenom", "email", "dateInscription"]
    },
    "Evenement": {
      "title": "Evenement",
      "type": "object",
      "description": "Événement de l'association.",
      "properties": {
        "titre": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "lieu": { "type": "string" },
        "prix": { "type": "number" }
      },
      "required": ["titre", "description", "date", "lieu", "prix"]
    },
    "Inscription": {
      "title": "Inscription",
      "type": "object",
      "description": "Inscription d'un adhérent à un événement.",
      "properties": {
        "id_evenement": { "type": "string" },
        "id_adherent": { "type": "string" },
        "a_paye": { "type": "boolean" },
        "date_inscription": { "type": "string", "format": "date-time" }
      },
      "required": ["id_evenement", "id_adherent", "a_paye", "date_inscription"]
    },
    "Cotisation": {
        "title": "Cotisation",
        "type": "object",
        "description": "Paiement annuel.",
        "properties": {
          "adherentId": { "type": "string" },
          "annee": { "type": "number" },
          "datePaiement": { "type": "string", "format": "date-time" },
          "montant": { "type": "number" }
        }
    },
    "CampagneEmail": {
      "title": "CampagneEmail",
      "type": "object",
      "properties": {
        "sujet": { "type": "string" },
        "corps": { "type": "string" },
        "dateEnvoi": { "type": "string", "format": "date-time" },
        "nbDestinataires": { "type": "number" }
      }
    },
    "LogEmail": {
      "title": "LogEmail",
      "type": "object",
      "properties": {
        "campaignId": { "type": "string" },
        "adherentId": { "type": "string" },
        "email": { "type": "string" },
        "ouvert": { "type": "boolean" },
        "dateOuverture": { "type": "string", "format": "date-time" }
      }
    },
    "LogAnniversaire": {
      "title": "LogAnniversaire",
      "type": "object",
      "properties": {
        "id_adherent": { "type": "string" },
        "date_envoi": { "type": "string" },
        "statut": { "type": "string", "enum": ["envoyé"] }
      }
    },
    "EmailTracking": {
      "title": "EmailTracking",
      "type": "object",
      "properties": {
        "jeton": { "type": "string" },
        "adherentId": { "type": "string" },
        "campagneId": { "type": "string" },
        "statut": { "type": "string", "enum": ["envoyé", "confirmé"] },
        "dateEnvoi": { "type": "string", "format": "date-time" },
        "dateLecture": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/admins/{userId}": {
      "schema": "#/backend/entities/Admin",
      "description": "Profils des administrateurs."
    },
    "/adherents/{adherentId}": {
      "schema": "#/backend/entities/Adherent",
      "description": "Liste des membres."
    },
    "/evenements/{evenementId}": {
      "schema": "#/backend/entities/Evenement",
      "description": "Événements."
    },
    "/inscriptions/{inscriptionId}": {
      "schema": "#/backend/entities/Inscription",
      "description": "Inscriptions aux événements."
    },
    "/cotisations/{cotisationId}": {
      "schema": "#/backend/entities/Cotisation",
      "description": "Cotisations annuelles."
    },
    "/logs_admin/{logId}": {
      "schema": "#/backend/entities/LogAdmin",
      "description": "Audit des actions."
    },
    "/email_campaigns/{campaignId}": {
      "schema": "#/backend/entities/CampagneEmail",
      "description": "Historique des campagnes e-mailing."
    },
    "/email_logs/{logId}": {
      "schema": "#/backend/entities/LogEmail",
      "description": "Logs individuels d'envoi et tracking."
    },
    "/logs_anniversaires/{logId}": {
      "schema": "#/backend/entities/LogAnniversaire",
      "description": "Suivi des envois d'emails d'anniversaire."
    },
    "/email_tracking/{jeton}": {
      "schema": "#/backend/entities/EmailTracking",
      "description": "Suivi manuel de réception des e-mails."
    }
  }
}
