
{
  "entities": {
    "Admin": {
      "title": "Admin",
      "type": "object",
      "description": "Représente un compte administrateur de la plateforme.",
      "properties": {
        "prenom": { "type": "string" },
        "nom": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "description": "Titre ou poste (ex: Président)" }
      },
      "required": ["prenom", "email"]
    },
    "Adherent": {
      "title": "Adherent",
      "type": "object",
      "description": "Membre de l'association H2vl.",
      "properties": {
        "nom": { "type": "string" },
        "prenom": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telephone": { "type": "string" },
        "dateInscription": { "type": "string", "format": "date-time" }
      },
      "required": ["nom", "prenom", "email", "dateInscription"]
    },
    "Evenement": {
      "title": "Evenement",
      "type": "object",
      "description": "Événement organisé par l'association.",
      "properties": {
        "titre": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "lieu": { "type": "string" },
        "prix": { "type": "number" }
      },
      "required": ["titre", "description", "date", "lieu", "prix"]
    },
    "Inscription": {
      "title": "Inscription",
      "type": "object",
      "description": "Inscription d'un adhérent à un événement.",
      "properties": {
        "id_evenement": { "type": "string" },
        "id_adherent": { "type": "string" },
        "a_paye": { "type": "boolean" },
        "date_inscription": { "type": "string", "format": "date-time" }
      },
      "required": ["id_evenement", "id_adherent", "a_paye", "date_inscription"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/admins/{userId}": {
      "schema": "#/backend/entities/Admin",
      "description": "Profils des administrateurs. L'existence d'un doc ici donne les droits Admin."
    },
    "/adherents/{adherentId}": {
      "schema": "#/backend/entities/Adherent",
      "description": "Liste des membres gérée par les administrateurs."
    },
    "/evenements/{evenementId}": {
      "schema": "#/backend/entities/Evenement",
      "description": "Événements de l'association."
    },
    "/inscriptions/{inscriptionId}": {
      "schema": "#/backend/entities/Inscription",
      "description": "Inscriptions aux événements."
    },
    "/cotisations/{cotisationId}": {
      "schema": "#/backend/entities/Cotisation",
      "description": "Historique des paiements de cotisations."
    },
    "/logs_admin/{logId}": {
      "schema": "#/backend/entities/LogAdmin",
      "description": "Journal d'audit des actions administratives."
    }
  }
}
