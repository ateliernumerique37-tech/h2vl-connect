
{
  "entities": {
    "Adherent": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Adherent",
      "type": "object",
      "description": "Represents a member of the H2vl association.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Adherent entity."
        },
        "nom": {
          "type": "string",
          "description": "The last name of the association member."
        },
        "prenom": {
          "type": "string",
          "description": "The first name of the association member."
        },
        "email": {
          "type": "string",
          "description": "The email address of the association member, used for communication.",
          "format": "email"
        },
        "telephone": {
          "type": "string",
          "description": "The phone number of the association member."
        },
        "dateInscription": {
          "type": "string",
          "description": "The date and time when the member joined the association.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "nom",
        "prenom",
        "email",
        "dateInscription"
      ]
    },
    "Evenement": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Evenement",
      "type": "object",
      "description": "Represents an event organized by the H2vl association.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Evenement entity."
        },
        "titre": {
          "type": "string",
          "description": "The title or name of the event."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the event, including its purpose and activities."
        },
        "date": {
          "type": "string",
          "description": "The date and time when the event is scheduled to take place.",
          "format": "date-time"
        },
        "lieu": {
          "type": "string",
          "description": "The physical or virtual location where the event will be held."
        },
        "prix": {
          "type": "number",
          "description": "The cost of attending the event."
        }
      },
      "required": [
        "id",
        "titre",
        "description",
        "date",
        "lieu",
        "prix"
      ]
    },
    "Inscription": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Inscription",
      "type": "object",
      "description": "Represents a member's registration for a specific event.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Inscription entity."
        },
        "evenementId": {
          "type": "string",
          "description": "Reference to the Evenement this registration is for."
        },
        "adherentId": {
          "type": "string",
          "description": "Reference to the Adherent who made this registration."
        },
        "aPaye": {
          "type": "boolean",
          "description": "Indicates whether the payment has been made."
        },
        "dateInscription": {
          "type": "string",
          "description": "The date and time of registration.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "evenementId",
        "adherentId",
        "aPaye",
        "dateInscription"
      ]
    },
    "CampagneEmail": {
      "title": "CampagneEmail",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sujet": { "type": "string" },
        "corps": { "type": "string" },
        "dateEnvoi": { "type": "string", "format": "date-time" },
        "nbDestinataires": { "type": "number" }
      }
    },
    "EmailTracking": {
      "title": "EmailTracking",
      "type": "object",
      "properties": {
        "jeton": { "type": "string" },
        "adherentId": { "type": "string" },
        "campagneId": { "type": "string" },
        "statut": { "type": "string", "enum": ["envoyé", "confirmé"] },
        "dateEnvoi": { "type": "string", "format": "date-time" },
        "dateLecture": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/admins/{adminId}",
        "definition": {
          "entityName": "AdminProfile",
          "description": "Administrator profiles.",
          "params": [{ "name": "adminId", "description": "UID of the admin." }]
        }
      },
      {
        "path": "/adherents/{adherentId}",
        "definition": {
          "entityName": "Adherent",
          "description": "Member profiles.",
          "params": [{ "name": "adherentId", "description": "UID or unique ID." }]
        }
      },
      {
        "path": "/evenements/{evenementId}",
        "definition": {
          "entityName": "Evenement",
          "description": "Association events.",
          "params": [{ "name": "evenementId", "description": "Unique ID." }]
        }
      },
      {
        "path": "/inscriptions/{inscriptionId}",
        "definition": {
          "entityName": "Inscription",
          "description": "Event registrations.",
          "params": [{ "name": "inscriptionId", "description": "Unique ID." }]
        }
      },
      {
        "path": "/email_campaigns/{campaignId}",
        "definition": {
          "entityName": "CampagneEmail",
          "description": "History of sent email campaigns."
        }
      },
      {
        "path": "/email_tracking/{jeton}",
        "definition": {
          "entityName": "EmailTracking",
          "description": "Tracking documents for email confirmations."
        }
      }
    ]
  }
}
