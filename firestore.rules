
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * H2vl Connect Security Rules
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isAdministrateur() {
      return isAdmin() && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'Administrateur';
    }

    // --- COLLECTION RULES ---

    /** Profils administrateurs */
    match /admins/{adminId} {
      allow get: if isSignedIn() && (isOwner(adminId) || isAdmin());
      allow list: if isAdmin();
      // La création et suppression passent par l'API Firebase Admin SDK (serveur)
      // qui contourne les règles. Les clients ne peuvent jamais écrire directement.
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if false;
    }

    /** Membres de l'association */
    match /adherents/{adherentId} {
      // Lecture autorisée à tous les admins (nécessaire pour stats et communication)
      allow read: if isAdmin();
      // Écriture réservée aux Administrateurs uniquement (RGPD)
      allow write: if isAdministrateur();
    }

    /** Événements */
    match /evenements/{evenementId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /** Inscriptions aux événements */
    match /inscriptions/{inscriptionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /** Cotisations des membres */
    match /cotisations/{id} {
      // Lecture autorisée à tous les admins (statistiques)
      allow read: if isAdmin();
      // Écriture réservée aux Administrateurs uniquement
      allow write: if isAdministrateur();
    }

    /** Campagnes d'e-mails */
    match /email_campaigns/{id} {
      allow read, write: if isAdmin();
    }

    /** Suivi des e-mails (Tracking) - ACCÈS PUBLIC POUR LA VALIDATION */
    match /email_tracking/{document} {
      allow read, write: if true;
    }

    /** Logs d'anniversaires */
    match /logs_anniversaires/{id} {
      allow read, write: if isAdmin();
    }

    /** Logs d'administration */
    match /logs_admin/{id} {
      allow read, write: if isAdmin();
    }
    
    /** Invitations événements - ACCÈS PUBLIC EN LECTURE/ÉCRITURE POUR L'AUTO-INSCRIPTION */
    match /invitations_evenement/{jeton} {
      allow read, write: if true;
    }

    /** Jetons d'annulation d'inscription - ACCÈS PUBLIC EN LECTURE ET CRÉATION */
    match /annulations_inscription/{jeton} {
      allow read: if true;
      allow create: if true;
      // La mise à jour (marquage "utilisé") et la suppression passent par l'API Admin SDK
      allow update, delete: if false;
    }

    /** Ancienne collection roles_admins (compatibilité) */
    match /roles_admins/{id} {
      allow read: if isSignedIn();
    }
  }
}
