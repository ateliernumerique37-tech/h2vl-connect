
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    match /adherents/{adherentId} {
      allow read, write: if isAuthenticated();
    }

    match /evenements/{evenementId} {
      allow read, write: if isAuthenticated();
    }

    match /inscriptions/{inscriptionId} {
      allow read, write: if isAuthenticated();
    }

    match /cotisations/{cotisationId} {
      allow read, write: if isAuthenticated();
    }

    match /admins/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /logs_admin/{logId} {
      allow read, create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /email_campaigns/{campaignId} {
      allow read, write: if isAuthenticated();
    }

    match /email_logs/{logId} {
      allow read, write: if isAuthenticated();
      allow update: if true; 
    }

    match /logs_anniversaires/{logId} {
      allow read, write: if isAuthenticated();
    }
  }
}
