
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Fonctions d'aide ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Vérifie si l'utilisateur est le propriétaire du document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Vérifie si l'utilisateur est un administrateur enregistré
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- Règles des Collections ---

    // Collection des Administrateurs
    match /admins/{adminId} {
      // Un utilisateur peut lire son propre profil ou le créer
      allow get, create: if isOwner(adminId) || isAdmin();
      // Seul un admin peut lister ou supprimer d'autres admins
      allow list, update, delete: if isAdmin();
    }
    
    // Journal d'audit (Logs)
    match /logs_admin/{logId} {
      // Les admins peuvent tout faire (lecture/écriture)
      allow read, list, create: if isAdmin();
      allow update, delete: if false;
    }

    // Événements (Publics en lecture, gérés par les admins)
    match /evenements/{evenementId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    // Adhérents (Gérés exclusivement par les admins)
    match /adherents/{adherentId} {
      allow read, list, create, update, delete: if isAdmin();
    }

    // Inscriptions (Gérées exclusivement par les admins)
    match /inscriptions/{inscriptionId} {
      allow read, list, create, update, delete: if isAdmin();
    }

    // Cotisations (Gérées exclusivement par les admins)
    match /cotisations/{cotisationId} {
      allow read, list, create, update, delete: if isAdmin();
    }
  }
}
