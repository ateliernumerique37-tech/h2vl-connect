
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Fonctions d'aide ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Vérifie si l'utilisateur est un administrateur enregistré dans la collection 'admins'
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Vérifie si l'utilisateur est le propriétaire du document (basé sur l'UID)
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Règles par Collection ---

    // Collection des Administrateurs
    match /admins/{adminId} {
      // Un utilisateur peut lire ou créer son propre document d'admin (nécessaire pour l'auto-réparation)
      // Les admins existants peuvent tout faire sur cette collection.
      allow get, create: if isOwner(adminId) || isAdmin();
      allow list, update, delete: if isAdmin();
    }

    // Adhérents (Lecture et écriture réservées aux administrateurs)
    match /adherents/{adherentId} {
      allow read, write: if isAdmin();
    }

    // Événements (Publics en lecture pour la découverte, gestion réservée aux admins)
    match /evenements/{evenementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Inscriptions (Gestion réservée aux administrateurs)
    match /inscriptions/{inscriptionId} {
      allow read, write: if isAdmin();
    }

    // Cotisations (Gestion réservée aux administrateurs)
    match /cotisations/{cotisationId} {
      allow read, write: if isAdmin();
    }

    // Journal d'audit (Lecture et création réservées aux administrateurs)
    match /logs_admin/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
