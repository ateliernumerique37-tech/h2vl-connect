rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * Robust, role-based security model for H2vl.
     * Admin status is verified by the existence of a document in the 'admins' collection.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Checks if the user is an administrator.
     * Uses the 'admins' collection as the source of truth.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    /**
     * @description Administrator profiles.
     * Users can read/create their own profile. Admins can manage all.
     */
    match /admins/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Association members (Adherents).
     * Only admins can manage the database of members.
     */
    match /adherents/{adherentId} {
      allow read, write: if isAdmin();
    }

    /**
     * @description Association events.
     * Readable by any member, manageable only by admins.
     */
    match /evenements/{evenementId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description Event registrations.
     * Members can see their own, admins see all.
     */
    match /inscriptions/{inscriptionId} {
      allow get, list: if isSignedIn() && (isAdmin() || resource.data.adherentId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin() || (resource.data.adherentId == request.auth.uid && request.resource.data.adherentId == resource.data.adherentId);
      allow delete: if isAdmin() || resource.data.adherentId == request.auth.uid;
    }

    /**
     * @description Membership fees (Cotisations).
     * Managed exclusively by administrators.
     */
    match /cotisations/{cotisationId} {
      allow read, write: if isAdmin();
    }

    /**
     * @description Audit logs.
     * Readable and writable only by administrators.
     */
    match /logs_admin/{logId} {
      allow read, write: if isAdmin();
    }
    
    /**
     * @description Legacy/System paths.
     */
    match /roles_admin/{adminUid} {
      allow get: if isOwner(adminUid) || isAdmin();
      allow read, write: if isAdmin();
    }
  }
}