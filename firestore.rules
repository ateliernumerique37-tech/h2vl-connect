rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Vérifie si l'utilisateur est un administrateur.
     * Utilise la collection 'admins' comme source de vérité.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    /**
     * @description Profils Administrateurs.
     * Un utilisateur doit pouvoir lire son propre document pour que le système l'identifie.
     */
    match /admins/{userId} {
      allow get, create: if isOwner(userId);
      allow list, update, delete: if isAdmin();
    }

    /**
     * @description Adhérents de l'association.
     * Seuls les admins peuvent gérer les membres.
     */
    match /adherents/{adherentId} {
      allow read, write: if isAdmin();
    }

    /**
     * @description Événements.
     * Lisibles par tous les connectés, gérés par les admins.
     */
    match /evenements/{evenementId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description Inscriptions aux événements.
     * Les membres voient les leurs, les admins voient tout.
     */
    match /inscriptions/{inscriptionId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.id_adherent == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.id_adherent == request.auth.uid);
    }

    /**
     * @description Cotisations.
     * Gestion exclusive par les administrateurs.
     */
    match /cotisations/{cotisationId} {
      allow read, write: if isAdmin();
    }

    /**
     * @description Journal d'audit.
     */
    match /logs_admin/{logId} {
      allow read, write: if isAdmin();
    }

    /**
     * @description Compatibilité legacy.
     */
    match /roles_admin/{adminUid} {
      allow get: if isOwner(adminUid) || isAdmin();
      allow read, write: if isAdmin();
    }
  }
}