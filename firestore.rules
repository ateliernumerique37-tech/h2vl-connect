/**
 * Configuration des règles de sécurité Firestore pour H2vl Connect.
 * 
 * Ce modèle repose sur une distinction claire entre :
 * 1. Les Administrateurs : qui ont un accès total pour gérer l'association.
 * 2. Les Adhérents : qui sont des entités de données gérées par les admins.
 * 
 * Un utilisateur est admin si son UID existe dans la collection /admins.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Fonctions d'aide ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Vérifie si l'utilisateur est le propriétaire du document (utilisé pour les profils admins)
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Vérifie si l'utilisateur a un profil administrateur enregistré
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- Règles des Collections ---

    // Collection des Administrateurs
    match /admins/{adminId} {
      // Un utilisateur peut lire son propre profil ou le créer lors de l'inscription.
      // Un admin existant peut tout faire.
      allow get, create: if isOwner(adminId) || isAdmin();
      allow list, update, delete: if isAdmin();
    }
    
    // Journal d'audit (Logs)
    match /logs_admin/{logId} {
      allow read, list, create: if isAdmin();
      allow update, delete: if false;
    }

    // Événements (Publics en lecture, gérés par les admins)
    match /evenements/{evenementId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    // Adhérents (Gérés exclusivement par les admins)
    match /adherents/{adherentId} {
      allow read, list, create, update, delete: if isAdmin();
    }

    // Inscriptions (Gérées exclusivement par les admins)
    match /inscriptions/{inscriptionId} {
      allow read, list, create, update, delete: if isAdmin();
    }

    // Cotisations (Gérées exclusivement par les admins)
    match /cotisations/{cotisationId} {
      allow read, list, create, update, delete: if isAdmin();
    }
  }
}