
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Vérifie si l'utilisateur est un administrateur.
     * Utilise la collection 'admins' comme source de vérité.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Profils Administrateurs.
     * Un utilisateur peut lire et créer son propre profil.
     * Seul un administrateur peut lister ou supprimer d'autres administrateurs.
     */
    match /admins/{userId} {
      allow get, create: if isSignedIn() && request.auth.uid == userId;
      allow list, update, delete: if isAdmin();
    }

    /**
     * @description Adhérents. Accès réservé aux administrateurs.
     */
    match /adherents/{adherentId} {
      allow read, write: if isAdmin();
    }

    /**
     * @description Événements. Lisibles par tous, gérés par les admins.
     */
    match /evenements/{evenementId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description Inscriptions. Lisibles par tous (pour les listes d'événements), gérées par les admins ou l'intéressé.
     */
    match /inscriptions/{inscriptionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    /**
     * @description Cotisations et Logs. Gestion exclusive par les administrateurs.
     */
    match /cotisations/{cotisationId} {
      allow read, write: if isAdmin();
    }

    match /logs_admin/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
